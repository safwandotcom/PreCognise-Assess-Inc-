generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SessionStatus {
  SCHEDULED
  WAITING
  LIVE
  PAUSED
  ENDED
}

enum CandidateStatus {
  REGISTERED
  JOINED
  ACTIVE
  COMPLETED
  DISQUALIFIED
}

enum QuestionType {
  mcq
  psychometric
  rating
  image
}

model AssessmentSettings {
  id                   String   @id @default(cuid())

  // Anti-cheat toggles
  antiCheatTabSwitch   Boolean  @default(true)
  antiCheatContextMenu Boolean  @default(true)
  antiCheatCopyPaste   Boolean  @default(true)
  antiCheatScreenshot  Boolean  @default(true)
  antiCheatDevTools    Boolean  @default(true)

  // Exam behaviour
  speedBonusEnabled    Boolean  @default(true)
  gracePeriodSec       Int      @default(0)

  // Geo-restriction: comma-separated ISO-3166-1 alpha-2 codes (empty = no restriction)
  geoRestriction       String   @default("")

  updatedAt            DateTime @updatedAt
}

model OrgBranding {
  id            String   @id @default(cuid())
  orgName       String   @default("PreCognise")
  tagline       String   @default("Candidate Assessment")
  logoUrl       String?
  primaryColour String   @default("#3730A3")
  updatedAt     DateTime @updatedAt
}

model Campaign {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  active        Boolean   @default(true)
  expiresAt     DateTime?
  maxCandidates Int?
  createdAt     DateTime  @default(now())

  sessionId  String
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  candidates Candidate[]
}

model Session {
  id          String        @id @default(cuid())
  title       String        @default("Untitled Session")
  joinToken   String        @unique @default(cuid())
  status      SessionStatus @default(WAITING)
  scheduledAt DateTime?
  autoStart   Boolean       @default(false)
  startedAt   DateTime?
  createdAt   DateTime      @default(now())

  candidates Candidate[]
  questions  Question[]
  campaigns  Campaign[]
}

model Candidate {
  id                String          @id @default(cuid())
  rollNumber        String
  email             String
  passwordHash      String
  generatedPassword String?
  activeToken       String?         @unique
  name              String
  country           String?
  status            CandidateStatus @default(REGISTERED)
  disqualifyReason  String?
  tabSwitchCount    Int             @default(0)
  otpCode           String?
  otpExpiresAt      DateTime?

  sessionId  String
  session    Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  responses  Response[]

  @@unique([rollNumber, sessionId])
  @@unique([email, sessionId])
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType
  text          String
  imageUrl      String?
  options       Json
  correctOption Int?
  timeLimitSec  Int
  basePoints    Int
  speedBonusMax Int          @default(0)
  orderIndex    Int

  sessionId String
  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses Response[]
}

model Response {
  id             String   @id @default(cuid())
  answer         Json
  score          Int      @default(0)
  responseTimeMs Int
  createdAt      DateTime @default(now())

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([candidateId, questionId])
}
